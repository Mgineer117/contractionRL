# used to configure VS Code settings
!.vscode

# Outputs
**/output/*
**/outputs/*
**/videos/*
**/wandb/*
**/.neptune/*
docker/artifacts/
*.tmp

# Doc Outputs
**/docs/_build/*
**/generated/*

# Isaac-Sim packman
_isaac_sim*
_repo
_build
.lastformat

# Run artifacts. Three separate trees, by what the files ARE (not who wrote
# them) — see /data/ below for the third:
#   logs/        — RUN INFORMATION only (tfevents, per-run *.log, eval_results
#                  .json, checkpoints). Regenerable; safe to delete wholesale.
#   search/logs/ — hyperparameter-sweep run information (per-agent logs, the
#                  generated sweep.yaml, nohup redirects). Same character as
#                  logs/, kept beside search/ so a sweep is self-contained.
#                  Covered by the same **/logs/* rule below.
# The old logs/search/ location is retired — sweeps write to search/logs/ now.
**/runs/*
**/logs/*
**/recordings/*

# Training run artifacts (nohup redirects, tensorboard events, stray checkpoints)
nohup.out
**/*tfevents*
/checkpoints/

# Torch checkpoints — regenerable run artifacts, never committed.
**/*.pt
**/*.pth
**/*.ckpt

# Generated DATA (dynamics_data.npz, cm_data*.npz). Separate from logs/ because
# these are INPUTS to later runs of other algorithms rather than the output of
# one run — deleting logs/ must never force a re-synthesis. Ignored purely on
# size: the current set is ~800 MB (a single dynamics_data.npz is 154 MB), far
# past what belongs in git. The small tracked npz under visualization/cache/ is
# a deliberate exception and stays versioned.
# /data/

# Per-launch generated W&B sweep yamls (search.sh writes one per sweep, into
# search/logs/). The searched space itself is versioned in search/configs/.
search/sweep_*.yaml

# Pre-Trained Checkpoints
/.pretrained_checkpoints/

# Teleop Recorded Dataset
/datasets/

# Tests
tests/

# Docker history
.isaac-lab-docker-history

# TacSL sensor
**/tactile_record/*
**/gelsight_r15_data/*

# MOSEK license (personal/academic — see README.md's Installation section)
mosek.lic
